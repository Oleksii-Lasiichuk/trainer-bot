# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Groq API key from https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# Comma-separated Telegram numeric user IDs permitted to use the bot.
# Leave empty to open to anyone (NOT recommended — anyone could burn your Groq quota).
ALLOWED_TELEGRAM_USER_IDS=

# Database URL (SQLAlchemy async). Default = local SQLite file under ./data/.
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

LOG_LEVEL=INFO
MAX_HISTORY_MESSAGES=12
MAX_TOOL_ITERATIONS=5
REQUEST_TIMEOUT_SECONDS=30
# Soft cap on tokens per Groq request. 9000 keeps us under the 12k TPM ceiling on the free 70B tier.
GROQ_TOKEN_BUDGET=9000
